# ===== 必需 =====
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free

# ===== 可选 =====
# OpenCode Zen（若要使用 opencode/... 模型）
# OPENCODE_ZEN_API_KEY=your-opencode-zen-key-here

# 自定义配置（通常无需修改）
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_APP_NAME=NexusSite-AI
# OPENROUTER_HTTP_REFERER=http://localhost:3002